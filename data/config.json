{
  "brandAssetPolicy": {
    "preserveOriginalLogos": true,
    "applyThemeColorsToLogos": false,
    "allowLogoRecolor": false,
    "allowCssFiltersOnLogos": false,
    "allowLogoOpacityChange": false,
    "allowLogoDistortion": false,
    "pageOneHoverException": {
      "enabled": true,
      "scope": "container-only",
      "description": "Na Página 1, o hover colorido deve ser aplicado no card/container da marca, nunca alterando permanentemente o arquivo do logo.",
      "allowedTreatments": [
        "borda colorida no container",
        "glow discreto no container",
        "linha superior colorida no card",
        "fundo auxiliar sutil no card",
        "sombra leve no card",
        "escala leve do card"
      ],
      "forbiddenTreatments": [
        "recolorir arquivo do logo",
        "aplicar filtro diretamente no logo",
        "alterar opacidade do logo",
        "usar mix-blend-mode no logo",
        "substituir cores internas do logo"
      ]
    },
    "allowedLogoTreatment": [
      "preservar cores originais",
      "preservar proporção original",
      "usar object-fit: contain",
      "aplicar somente redimensionamento proporcional",
      "usar cores institucionais apenas em fundos, botões, bordas, textos e elementos gráficos",
      "usar hover colorido somente no container da marca na Página 1"
    ],
    "forbiddenLogoTreatment": [
      "recolorir logo",
      "converter logo para monocromático",
      "aplicar filter CSS diretamente no logo",
      "aplicar mix-blend-mode diretamente no logo",
      "alterar opacidade do logo",
      "distorcer proporção",
      "cortar área útil do logo",
      "substituir cores internas do logo pelas cores do tema"
    ]
  },
  "backgroundPolicy": {
    "backgroundImagesRequired": false,
    "fallbackMode": "theme-gradient",
    "description": "Os backgrounds cadastrados em data/companies.json são opcionais. Se o arquivo não existir, o sistema deve usar gradiente ou cor sólida baseada no tema da marca selecionada."
  },
  "edneyInstitutionalAssets": {
    "photoOne": "assets/images/edney/edney-institucional-01.png",
    "photoTwo": "assets/images/edney/edney-institucional-02.png",
    "status": "validated",
    "requiredBeforeBuild": false,
    "description": "Fotos finais do Edney Ulisses validadas no repositório para uso nos slides institucionais da proposta."
  },
  "typography": {
    "fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif",
    "fontPolicy": "usar tipografia padrão do sistema, sem dependência externa de fonte"
  },
  "groupBrand": {
    "name": "Grupo GPV",
    "logo": "assets/logos/grupo-gpv-negativo.png",
    "logoWhite": "assets/logos/grupo-gpv-negativo.png",
    "logoPositiveReference": "assets/logos/grupo-gpv-positivo.png",
    "preferredLogoUsage": "usar sempre o logo branco sobre fundo escuro dentro da paleta institucional",
    "legacyBarReference": "assets/logos/grupo-gpv.svg",
    "theme": {
      "primaryColor": "#252324",
      "secondaryColor": "#A5A09C",
      "accentColor": "#5BBFC8",
      "backgroundColor": "#252324",
      "textColor": "#FFFFFF",
      "mutedTextColor": "#A5A09C",
      "supportColors": {
        "cyan": "#5BBFC8",
        "red": "#E31838",
        "yellow": "#F5C32C",
        "blue": "#2F3D8E"
      }
    }
  },
  "responsible": {
    "name": "Rafael",
    "role": "Gerente Comercial",
    "company": "Grupo GPV",
    "phone": "",
    "email": "",
    "signatureImage": "assets/signatures/assinatura-rafael.png",
    "qrCodeImage": ""
  },
  "pdf": {
    "filenamePrefix": "Proposta_Comercial_GPV",
    "format": "a4",
    "orientation": "landscape",
    "margin": 0,
    "quality": 1,
    "useDedicatedPdfTemplate": true,
    "templatePolicy": "O PDF deve ser gerado a partir de template dedicado, separado da proposta interativa. Não exportar diretamente a tela animada."
  },
  "system": {
    "projectName": "GPV Sales Kit",
    "repository": "GPV_Sales_Kit",
    "version": "1.0.0"
  }
}
